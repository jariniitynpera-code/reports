# ============================================================
# Shopify Daily Report — Ympäristömuuttujat
# Kopioi tiedosto nimelle .env ja täytä arvot.
# ÄLÄ koskaan committaa .env-tiedostoa versionhallintaan.
# ============================================================

# ── Shopify ──────────────────────────────────────────────────
# Shopify-kaupan osoite (esim. your-store.myshopify.com)
# TÄRKEÄÄ: Käytä tuotantokaupan osoitetta, ei testistoreä!
SHOPIFY_SHOP=your-store.myshopify.com

# Custom app -tunnukset (Shopify Admin → Apps → Develop apps)
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# API-versio (suositus: jätä oletukseksi)
SHOPIFY_API_VERSION=2025-01

# ── Supabase ─────────────────────────────────────────────────
# Supabase-projektin URL (löytyy Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key (HUOM: pitää sisällään täydet oikeudet)
# Löytyy Project Settings → API → service_role
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── ClickUp ──────────────────────────────────────────────────
# ClickUp Personal API Token
# Löytyy: ClickUp → Profile → Apps → API Token
CLICKUP_API_KEY=pk_your_api_key_here

# Lista-ID jonne päiväraportit julkaistaan
# Löytyy: Avaa lista ClickUpissa → URL-palkista /l/XXXXXXXXXX
CLICKUP_LIST_ID=your_list_id_here

# Follow-up-tehtävien lista (jätä tyhjäksi = sama kuin raportit)
CLICKUP_TASKS_LIST_ID=

# ── Asetukset ────────────────────────────────────────────────
# Aikavyöhyke (IANA-muoto)
TIMEZONE=Europe/Helsinki

# Ajastusaika (käytetään dokumentaatiossa — cron asetetaan erikseen)
REPORT_CRON_TIME=07:30

# ── Google Calendar (valinnainen) ────────────────────────────────────
# Palvelutilin JSON-avaintiedosto (jätä tyhjäksi jos ei käytössä)
# Luo: Google Cloud Console → IAM → Palvelutilit → Luo avain (JSON)
# Jaa kalenteri palvelutilin sähköpostille (luku-oikeus riittää)
GCAL_CREDENTIALS_FILE=
# Kalenterin ID (primary = pääkalenteri)
GCAL_CALENDAR_ID=primary

# ── Slack (valinnainen) ──────────────────────────────────────────────
# Incoming Webhook URL
# Luo: api.slack.com → Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
# "true" = lähetetään myös green-raportit (oletus: vain yellow/red)
SLACK_NOTIFY_GREEN=false

# ── Sähköposti-ilmoitukset (valinnainen) ─────────────────────────────
# Vastaanottajan sähköposti
ALERT_EMAIL=jari.niitynpera@schoonersupply.com
# SMTP-palvelin (esim. smtp.gmail.com, smtp.office365.com)
SMTP_HOST=
SMTP_PORT=587
# Gmail: käytä App Password (google.com/account → Tietoturva → Sovellussalasanat)
SMTP_USER=
SMTP_PASS=
# "true" = lähetetään myös green-raportit sähköpostilla
EMAIL_NOTIFY_GREEN=false

# ── Varasto (valinnainen) ─────────────────────────────────────────────
# Hälytysraja kappaleissa (5 = varoitus kun alle 5 kpl jäljellä)
INVENTORY_LOW_STOCK_THRESHOLD=5
# "false" = ohitetaan varastotarkistus (nopeuttaa ajoa)
INVENTORY_CHECK_ENABLED=true
